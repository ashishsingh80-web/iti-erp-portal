# Postgres: for production (e.g. Vercel + Neon), prefer Neon's pooled connection string from the dashboard
# (serverless functions open many short-lived connections; pooling reduces latency and connection errors).
# Also choose the same cloud region for Vercel and Neon when possible—cross-region adds round-trip delay to every query.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/iti_erp_portal"
AUTH_SECRET="change-this-before-production"
NEXTAUTH_SECRET="replace-this-with-a-strong-secret"
NEXTAUTH_URL="http://localhost:3000"
AADHAAR_ENCRYPTION_KEY=""
NOTIFY_SMS_WEBHOOK_URL=""
NOTIFY_WHATSAPP_WEBHOOK_URL=""
NOTIFY_EMAIL_WEBHOOK_URL=""
NOTIFY_WEBHOOK_BEARER_TOKEN=""
